# НАСТРОЙКИ ПРИЛОЖЕНИЯ
APP_NAME="УчетТМЦ"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_TIMEZONE=Europe/Moscow

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# НАСТРОЙКИ КОМПАНИИ (ДЛЯ ИНТЕРФЕЙСА)
COMPANY_NAME="УчетТМЦ"
COMPANY_DESCRIPTION="Система учета оборудования и ТМЦ"
COMPANY_SHORT_NAME="УТМЦ"
COMPANY_EMAIL="support@company.com"
COMPANY_PHONE="+7 (999) 999-99-99"
COMPANY_LOGO=""

# БАЗА ДАННЫХ
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=equipment_db
DB_USERNAME=root
DB_PASSWORD=

# НАСТРОЙКИ СЕССИЙ
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#НАСТРОЙКИ ПОЧТЫ
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mail.ru
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USERNAME="ваша_почта@mail.ru"
MAIL_PASSWORD="сгенерированный_пароль"
MAIL_FROM_ADDRESS="ваша_почта@mail.ru"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# QR-КОДЫ
QR_CODE_SIZE=300
QR_CODE_MARGIN=10
